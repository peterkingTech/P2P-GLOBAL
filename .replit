modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["u-root-cmds"]

[userenv]

[userenv.development]
EXPO_PUBLIC_API_URL = "https://da8e3f13-8b53-4390-afdc-2f35a0291e28-00-1m8yb5gd0pptd.picard.replit.dev/api"
